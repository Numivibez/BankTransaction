@model IEnumerable<BankTransaction.Models.Transaction>

@{
    ViewData["Title"] = "Index";
}

<div>
    <div class="col-md-8 offset-md-2">
        <h1>PassBook</h1>

        <table class="table">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.AccountNumber)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.BeneficiaryName)
                    </th>
                    @* <th>
                @Html.DisplayNameFor(model => model.BankName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SwiftCode)
            </th> *@
                    <th>
                        @Html.DisplayNameFor(model => model.Date)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Amount)
                    </th>

                    <th>
                        <a asp-action="AddOrEdit" class="btn btn-sm btn-success"><i class="fa-solid fa-plus"></i>New</a>

                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(model => item.AccountNumber)
                        </td>
                        <td>
                            @Html.DisplayFor(model => item.BeneficiaryName)
                        </td>
                        @* <td>
                @Html.DisplayFor(model => item.BankName)
            </td>
            <td>
                @Html.DisplayFor(model => item.SwiftCode)
            </td> *@
                        <td>
                            @Html.DisplayFor(model => item.Date)
                        </td>
                        <td>
                            @Html.DisplayFor(model => item.Amount)
                        </td>

                        <td>

                            @* <a asp-action="Details" asp-route-id="@item.TransactionId">Details</a> | *@
                            <form asp-action="Delete" asp-route-id="@item.TransactionId" method="post">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="AddOrEdit" asp-route-id="@item.TransactionId" class="btn btn-warning">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>

                                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this transaction?')">
                                        <i class="far fa-trash-alt"></i>
                                    </button>
                                </div>
                            </form>
                            @* <a asp-action="Delete" asp-route-id="@item.TransactionId">Delete</a> *@
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
